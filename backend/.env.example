# ─── SocietyPro — Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
UPLOAD_DIR=./uploads

# ── Database ─────────────────────────────────────────────────────────────────
DB_TYPE=sqlite             # sqlite | mssql
SQLITE_PATH=./societypro.db

# MSSQL (only needed when DB_TYPE=mssql)
MSSQL_SERVER=localhost\SQLEXPRESS
MSSQL_DATABASE=societypro
MSSQL_USERNAME=sa
MSSQL_PASSWORD=YourStrongPassword!

# ── SMS ──────────────────────────────────────────────────────────────────────
SMS_PROVIDER=twilio        # twilio | msg91
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890
MSG91_AUTH_KEY=

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=smtp        # smtp | sendgrid
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@societypro.com
SENDGRID_API_KEY=

# ── WhatsApp ─────────────────────────────────────────────────────────────────
WHATSAPP_PROVIDER=twilio   # twilio | wati | gupshup
WHATSAPP_FROM=+91xxxxxxxxxx
WATI_API_ENDPOINT=
WATI_ACCESS_TOKEN=
GUPSHUP_API_KEY=
GUPSHUP_APP_NAME=

# ── Redis (optional, for Celery background jobs) ──────────────────────────────
# REDIS_URL=redis://localhost:6379/0
